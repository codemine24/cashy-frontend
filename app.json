{
  "expo": {
    "name": "Cashy",

    "slug": "cashy",

    "version": "1.0.0",

    "orientation": "portrait",

    "icon": "./assets/images/app-icon.png",

    "scheme": "cashy-expense-manager",

    "userInterfaceStyle": "light",

    "newArchEnabled": true,

    "backgroundColor": "#ffffff",

    "android": {
      "package": "com.codemine.cashy",
      "versionCode": 16,
      "version": "1.0.16",
      "softwareKeyboardLayoutMode": "pan",

      "adaptiveIcon": {
        "backgroundColor": "#02929a",

        "foregroundImage": "./assets/images/app-icon-foreground.png",

        "monochromeImage": "./assets/images/app-icon-monochromic.png"
      },

      "permissions": ["INTERNET", "CAMERA"],

      "edgeToEdgeEnabled": true,

      "predictiveBackGestureEnabled": false
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",

        {
          "image": "./assets/images/splash-icon.png",

          "imageWidth": 200,

          "resizeMode": "contain",

          "backgroundColor": "#ffffff",

          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],

      "@react-native-community/datetimepicker",

      "expo-localization",

      "expo-navigation-bar",

      "expo-secure-store",

      "expo-web-browser",

      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrl": "ios://bundle",
          "iosUrlScheme": "com.googleusercontent.apps.68140526274-cbimppqqje5k18q1aqf4cqlng98ibi5b",
          "androidUrl": "com.codemine.cashy"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,

      "reactCompiler": true
    },

    "extra": {
      "router": {},

      "eas": {
        "projectId": "428b74db-754f-4501-835c-69c5372d0bd3"
      }
    },

    "ios": {
      "bundleIdentifier": "com.codemine.cashy"
    }
  }
}
